{
  "manifest_version": 3,
  "name": "JobSwiper — AI Job Prep",
  "version": "0.1.0",
  "description": "Save jobs from any website. Generate tailored CVs, cover letters & interview prep with AI.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.indeed.com/*",
    "https://*.indeed.fr/*",
    "https://*.indeed.de/*",
    "https://*.indeed.co.uk/*",
    "https://*.indeed.co.in/*",
    "https://*.indeed.ca/*",
    "https://*.indeed.com.au/*",
    "https://*.linkedin.com/*",
    "https://*.glassdoor.com/*",
    "https://*.glassdoor.fr/*",
    "https://*.glassdoor.de/*",
    "https://jobswiper.ai/*",
    "https://www.jobswiper.ai/*",
    "http://localhost:3000/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.icims.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.taleo.net/*",
    "https://*.workable.com/*",
    "https://*.breezy.hr/*",
    "https://*.ashbyhq.com/*",
    "https://*.recruitee.com/*",
    "https://*.bamboohr.com/*",
    "https://*.jazz.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.indeed.com/*",
        "https://*.indeed.fr/*",
        "https://*.indeed.de/*",
        "https://*.indeed.co.uk/*",
        "https://*.indeed.co.in/*",
        "https://*.indeed.ca/*",
        "https://*.indeed.com.au/*"
      ],
      "js": ["content/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.linkedin.com/jobs/*"
      ],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://jobswiper.ai/*",
        "https://www.jobswiper.ai/*",
        "http://localhost:3000/*"
      ],
      "js": ["content/detect.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.icims.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.taleo.net/*",
        "https://*.workable.com/*",
        "https://*.breezy.hr/*",
        "https://*.ashbyhq.com/*",
        "https://*.recruitee.com/*",
        "https://*.bamboohr.com/*",
        "https://*.jazz.co/*"
      ],
      "js": ["content/autofill.js"],
      "css": ["content/jobswiper.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
